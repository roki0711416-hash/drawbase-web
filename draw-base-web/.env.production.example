# ============================================================
# DRAW BASE — 本番環境用環境変数テンプレート
# ============================================================

# --- API サーバー (api.drawbase.net) 用 ---
# Web フロントエンドには DATABASE_URL, STRIPE_* は不要

# Database
DATABASE_URL="postgresql://user:password@your-db-host:5432/drawbase?schema=public"

# NextAuth (API/Web 両方で同じ SECRET を使用)
NEXTAUTH_URL="https://api.drawbase.net"
NEXTAUTH_SECRET="generate-a-secure-random-string"

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- App URLs ---
# Web frontend URL
NEXT_PUBLIC_WEB_URL="https://drawbase.net"
# API backend URL (API サーバー自身では空文字)
# Web フロントエンドでは "https://api.drawbase.net"
NEXT_PUBLIC_API_URL=""
# Legacy compat
NEXT_PUBLIC_APP_URL="https://drawbase.net"
NEXT_PUBLIC_APP_NAME="DRAW BASE"

# Upload
UPLOAD_DIR="/var/uploads"
